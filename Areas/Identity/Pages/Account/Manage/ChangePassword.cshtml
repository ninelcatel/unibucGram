@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container py-3 py-md-4" style="max-width: 950px;">
   
    <!-- Navbar + Card Section -->
    <div class="row g-3 align-items-start">
        <!-- Left Sidebar Navigation - Aligned with card -->
        <div class="col-12 col-md-3 col-lg-2">
            <div style="position: sticky; top: 76px;">
                <partial name="_ManageNav" />
            </div>
        </div>

        <!-- Main Content Card -->
        <div class="col-12 col-md-9 col-lg-10">
            <div class="card form-container">
                <div class="card-body p-3 p-md-4">
                    
                    <partial name="_StatusMessage" for="StatusMessage" />

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="form-floating mb-2">
                            <input asp-for="Input.OldPassword" class="form-control form-control-sm" type="password" autocomplete="current-password" placeholder="Current Password" />
                            <label asp-for="Input.OldPassword" class="small">Current Password</label>
                            <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                        </div>
                        
                        <div class="form-floating mb-2">
                            <input asp-for="Input.NewPassword" class="form-control form-control-sm" type="password" autocomplete="new-password" placeholder="New Password" />
                            <label asp-for="Input.NewPassword" class="small">New Password</label>
                            <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                        </div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Input.ConfirmPassword" class="form-control form-control-sm" type="password" autocomplete="new-password" placeholder="Confirm Password" />
                            <label asp-for="Input.ConfirmPassword" class="small">Confirm New Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>
                        
                        <div class="d-flex justify-content-center">
                            <button type="submit" class="btn btn-primary btn-sm px-4">Update Password</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}