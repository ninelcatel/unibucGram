@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.FirstName" class="form-control" placeholder="First Name" />
                <label asp-for="Input.FirstName" class="form-label"></label>
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.LastName" class="form-control" placeholder="Last Name" />
                <label asp-for="Input.LastName" class="form-label"></label>
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.DateOfBirth" class="form-control" type="date" />
                <label asp-for="Input.DateOfBirth" class="form-label"></label>
                <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <textarea asp-for="Input.Bio" class="form-control" style="height: 100px" maxlength="200" placeholder="Bio"></textarea>
                <label asp-for="Input.Bio" class="form-label"></label>
                <span asp-validation-for="Input.Bio" class="text-danger"></span>
                <small class="form-text text-muted"><span id="bioCounter">0</span>/200 characters</small>
            </div>
            
            <div class="form-check mb-3">
                <input asp-for="Input.IsPrivate" class="form-check-input" />
                <label asp-for="Input.IsPrivate" class="form-check-label"></label>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" type="tel" placeholder="+40 123 456 789" />
                <label asp-for="Input.PhoneNumber"></label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                <small class="form-text text-muted">Format: +40 123 456 789 or 0712345678</small>
            </div>
            
            <div class="mb-3">
                <label asp-for="Input.ProfilePicture" class="form-label"></label>
                <input asp-for="Input.ProfilePicture" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="Input.ProfilePicture" class="text-danger"></span>
                @if (!string.IsNullOrEmpty(Model.Input.PfpURL))
                {
                    <img src="@Model.Input.PfpURL" alt="Profile Picture" class="mt-2 rounded-circle" style="width: 80px; height: 80px; object-fit: cover;" />
                }
            </div>
            
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Save</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Bio character counter
            var bioTextarea = $('#Input_Bio');
            var bioCounter = $('#bioCounter');
            
            function updateBioCounter() {
                var count = bioTextarea.val().length;
                bioCounter.text(count);
                if (count > 200) {
                    bioCounter.css('color', 'red');
                } else {
                    bioCounter.css('color', 'inherit');
                }
            }
            
            bioTextarea.on('input', updateBioCounter);
            updateBioCounter(); // Initialize counter
            
            // Custom validation for phone number
            $.validator.addMethod("phoneValidation", function(value, element) {
                if (!value) return true; // Optional field
                // Match international format (+40 123 456 789) or Romanian format (0712345678)
                return /^(\+?\d{1,3}[\s.-]?)?\(?\d{3}\)?[\s.-]?\d{3}[\s.-]?\d{3,4}$/.test(value);
            }, "Please enter a valid phone number (e.g., +40 123 456 789 or 0712345678).");
            
            // Apply custom validation to phone number
            $('#Input_PhoneNumber').rules('add', {
                phoneValidation: true
            });
            
            // Enhance form validation
            $('#profile-form').validate({
                errorClass: 'text-danger',
                errorElement: 'span',
                highlight: function(element) {
                    $(element).addClass('is-invalid');
                },
                unhighlight: function(element) {
                    $(element).removeClass('is-invalid');
                }
            });
        });
    </script>
}