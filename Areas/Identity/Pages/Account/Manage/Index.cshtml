@page
@model unibucGram.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Edit Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
    Layout = "/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.css" rel="stylesheet">

<div class="container py-3 py-md-4" style="max-width: 950px;">

    <!-- Navbar + Card Section -->
    <div class="row g-3 align-items-start">
        <!-- Left Sidebar Navigation - Aligned with card -->
        <div class="col-12 col-md-3 col-lg-2">
            <div style="position: sticky; top: 76px;">
                <partial name="_ManageNav" />
            </div>
        </div>

        <!-- Main Content Card -->
        <div class="col-12 col-md-9 col-lg-10">
            <!-- Profile Card -->
            <div class="card form-container">
                <div class="card-body p-3 p-md-4">
                    <partial name="_StatusMessage" for="StatusMessage" />

                    <form id="profile-form" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Profile Picture Section -->
                        <div class="text-center mb-4">
                            <img src="@Url.Content(string.IsNullOrWhiteSpace(Model.Input?.PfpURL) 
                                ? "~/uploads/default_pfp.jpg" 
                                : Model.Input.PfpURL)" 
                                alt="Profile Picture" 
                                style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; border: 3px solid var(--accent-purple); box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
                                id="profile-picture-preview" />

                            <div class="mt-2">
                                <label for="profile-picture-input" class="btn btn-primary btn-sm px-2">
                                    <i class="bi bi-camera me-1"></i>Change
                                </label>
                                <input type="file" id="profile-picture-input" name="ProfilePictureFile" class="d-none" accept="image/*">
                                <input type="hidden" asp-for="Input.PfpURL" id="pfp-url-input" />
                                <input type="hidden" asp-for="Input.ProfilePictureBase64" id="profile-picture-base64" />
                                
                                @if (!string.IsNullOrWhiteSpace(Model.Input?.PfpURL) && Model.Input.PfpURL != "/uploads/default_pfp.jpg")
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-sm ms-1 px-2" id="remove-pfp-btn">
                                        <i class="bi bi-trash me-1"></i>Remove
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Form Fields -->
                        <div class="form-floating mb-2">
                            <input asp-for="Username" class="form-control form-control-sm" disabled />
                            <label asp-for="Username" class="small">Username</label>
                        </div>

                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <div class="form-floating">
                                    <input asp-for="Input.FirstName" class="form-control form-control-sm" placeholder="First Name" />
                                    <label asp-for="Input.FirstName" class="small">First Name</label>
                                    <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-floating">
                                    <input asp-for="Input.LastName" class="form-control form-control-sm" placeholder="Last Name" />
                                    <label asp-for="Input.LastName" class="small">Last Name</label>
                                    <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-2">
                            <input asp-for="Input.DateOfBirth" class="form-control form-control-sm" type="date" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <label asp-for="Input.DateOfBirth" class="small">Date of Birth</label>
                            <span asp-validation-for="Input.DateOfBirth" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-2">
                            <textarea asp-for="Input.Bio" class="form-control form-control-sm" placeholder="Tell us about yourself" style="height: 70px;"></textarea>
                            <label asp-for="Input.Bio" class="small">Bio</label>
                            <span asp-validation-for="Input.Bio" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Input.IsPrivate" class="form-check-input purple-checkbox" type="checkbox" id="isPrivateCheckbox" />
                            <label asp-for="Input.IsPrivate" class="form-check-label small ms-2">Private Account</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.PhoneNumber" class="form-control form-control-sm" placeholder="Phone number" />
                            <label asp-for="Input.PhoneNumber" class="small">Phone Number</label>
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-center">
                            <button id="update-profile-button" type="submit" class="btn btn-primary btn-sm px-4">
                                <i class="bi bi-check-circle me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Cropper Modal -->
<div class="modal fade" id="cropper-modal" tabindex="-1" aria-labelledby="cropperModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cropperModalLabel">Crop Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="img-container">
                    <img id="cropper-image" src="" alt="Image to crop">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="crop-button">Crop & Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const removePfpBtn = document.getElementById('remove-pfp-btn');
            if (removePfpBtn) {
                removePfpBtn.addEventListener('click', () => {
                    const preview = document.getElementById('profile-picture-preview');
                    const pfpUrlInput = document.getElementById('pfp-url-input');
                    
                    preview.src = '/uploads/default_pfp.jpg';
                    pfpUrlInput.value = '/uploads/default_pfp.jpg';
                    removePfpBtn.style.display = 'none';
                    document.getElementById('profile-picture-input').value = '';
                });
            }

            const imageInput = document.getElementById('profile-picture-input');
            const preview = document.getElementById('profile-picture-preview');
            const modal = new bootstrap.Modal(document.getElementById('cropper-modal'));
            const cropperImage = document.getElementById('cropper-image');
            const cropButton = document.getElementById('crop-button');
            let cropper;

            imageInput.addEventListener('change', (e) => {
                const files = e.target.files;
                if (files && files.length > 0) {
                    const file = files[0];
                    const reader = new FileReader();
                    reader.onload = (event) => {
                        cropperImage.src = event.target.result;
                        modal.show();
                    };
                    reader.readAsDataURL(file);
                }
            });

            document.getElementById('cropper-modal').addEventListener('shown.bs.modal', () => {
                cropper = new Cropper(cropperImage, {
                    aspectRatio: 1,
                    viewMode: 1,
                    autoCropArea: 0.8,
                });
            });

            document.getElementById('cropper-modal').addEventListener('hidden.bs.modal', () => {
                if (cropper) {
                    cropper.destroy();
                    cropper = null;
                }
                imageInput.value = '';
            });

            cropButton.addEventListener('click', () => {
                if (cropper) {
                    const canvas = cropper.getCroppedCanvas({
                        width: 300,
                        height: 300,
                        imageSmoothingQuality: 'high',
                    });

                    const base64Data = canvas.toDataURL('image/jpeg', 0.9);
                    preview.src = base64Data;
                    document.getElementById('profile-picture-base64').value = base64Data;

                    if (removePfpBtn) {
                        removePfpBtn.style.display = 'inline-block';
                    }
                }
                modal.hide();
            });
        });
    </script>
}