            </div>
        </div>
    </div>

}
else
{
    <!-- Landing Page for Guests -->
    <div class="container mt-5 text-center">
        <h1 class="display-4 fw-bold text-purple mb-4">Welcome to unibucGram</h1>
        <p class="lead mb-5">Connect with your university colleagues.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-5">Log In</a>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary btn-lg px-5">Register</a>
        </div>
    </div>
}