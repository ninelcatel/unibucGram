@using Microsoft.AspNetCore.Identity
@using unibucGram.Models
@inject SignInManager<User> SignInManager

@{
    ViewData["Title"] = "Home";
}

@if (SignInManager.IsSignedIn(User))
{
    <div class="home-layout">

        <!-- 1. LEFT SIDEBAR (Suggested) -->
        <aside class="sidebar sidebar-left" id="sidebar-left">
            <button class="sidebar-toggle" onclick="toggleSidebar('left')" title="Toggle Menu">
                <i class="bi bi-chevron-left toggle-icon"></i>
            </button>

            <div class="sidebar-label">SUGGESTED</div>

            <div class="sidebar-content">
                <h5 class="fw-bold mb-4 text-purple text-center">Suggested</h5>
                <!-- Content goes here -->
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-light rounded-circle" style="width: 40px; height: 40px;"></div>
                    <div class="ms-2">
                        <div class="fw-bold small">student_1</div>
                        <div class="text-muted small">New to unibucGram</div>
                    </div>
                </div>
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-light rounded-circle" style="width: 40px; height: 40px;"></div>
                    <div class="ms-2">
                        <div class="fw-bold small">prof_math</div>
                        <div class="text-muted small">Followed by 3 others</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- 2. CENTER CONTENT (Posts) -->
        <main class="main-content">
            <div id="feed-container" style="width: 100%; display: flex; flex-direction: column; align-items: center;">
                @if(User.IsInRole("Guest"))
                {
                    <h5 class="text-center text-muted mt-5">Welcome! Please Verify your email via this button to unlock the full features of unibucGram.</h5>
                    <div class="d-flex justify-content-center mb-4">
                        <form asp-controller="Home" asp-action="VerifyAccount" method="post">
                            <button type="submit" class="btn btn-primary">Verify your account</button>
                        </form>
                    </div>
                }
                else
                {
                    <partial name="_PostFeed" model="Model" />
                }
            </div>

            <div id="loading" class="text-center my-4" style="display: none;">
                <div class="spinner-border text-purple" role="status"></div>
            </div>
        </main>

        <!-- 3. RIGHT SIDEBAR (Conversations) -->
        <aside class="sidebar sidebar-right" id="sidebar-right">
            <button class="sidebar-toggle" onclick="toggleSidebar('right')" title="Toggle Chat">
                <i class="bi bi-chevron-right toggle-icon"></i>
            </button>

            <div class="sidebar-label">MESSAGES</div>

            <div class="sidebar-content">
                <h5 class="fw-bold mb-4 text-purple text-center">Conversations</h5>
                @if (TempData["message"] != null)
{
    <div class="text-center mb-3">
        <div class="alert alert-info alert-dismissible fade show" role="alert" style="z-index: 9999;">
            @TempData["message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}
                <button class="btn btn-primary w-100 mb-3 d-flex align-items-center justify-content-center gap-2"
                    data-bs-toggle="modal" data-bs-target="#createGroupModal">
                    <i class="bi bi-plus-circle"></i> Create Group
                </button>
                <div id="userGroupsList" class="list-group list-group-flush">
                    <!-- Groups will be loaded here by JavaScript -->
                    <div class="text-center text-muted mt-3">
                        <div class="spinner-border spinner-border-sm text-purple" role="status"></div>
                    </div>
                </div>
            </div>
        </aside>

    </div>

    <!-- modal for creating  a group -->
    <div class="modal fade" id="createGroupModal" tabindex="-1" aria-labelledby="createGroupModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold text-purple" id="createGroupModalLabel">Create New Group</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="createGroupForm" asp-action="Create" asp-controller="Group" method="post">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" name="Name" id="groupName" placeholder="Group Name" required>
                            <label for="Name">Group Name</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">SELECT MEMBERS</label>
                            
                            <div class="search-wrapper_chat mb-2" style="max-width:100%;">
                                <input type="text" id="searchInput_chat" class="form-control border-0" 
                                    placeholder="Search followers..." aria-label="Search" autocomplete="off" />
                                <div id="searchResults_chat" class="search-results bg-white border rounded-2 shadow-sm"
                                    aria-hidden="true"></div>
                            </div>
                            
                            <!-- The container for the chips -->
                            <div id="selectedMembers" class="mt-2"></div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="createGroupForm" class="btn btn-primary">Create Group</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="groupChatModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg" style="height: 80vh;">
                
                <!-- Header -->
                <div class="modal-header border-bottom-0" style="background: linear-gradient(135deg, #6f42c1 0%, #5a32a3 100%);">
                    <div class="d-flex align-items-center">
                        <!-- Group Image -->
                        <div id="groupHeaderImage" class="rounded-circle me-3" 
                             style="width: 48px; height: 48px; min-width: 48px; min-height: 48px; background-size: cover; background-position: center; background-repeat: no-repeat; border: 2px solid white; flex-shrink: 0;">
                        
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold mb-0 text-white" id="chatModalTitle">Group Name</h5>
                            <small class="text-white-50" id="groupHeaderSubtitle">Loading...</small>
                        </div>
                    </div>
                    <button id="groupInfoToggle" type="button" class="btn btn-link text-white me-2" title="Group info">
                        <i class="bi bi-info-circle" style="font-size: 1.25rem;"></i>
                    </button>

                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <!-- Sliding info panel (hidden by default, slides in from right) -->
                   <div id="groupInfoPanel" class="group-info-panel shadow">
                    <div class="p-3 border-bottom">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div>
                                <h6 class="mb-0 fw-bold" id="panelGroupName">Group Name</h6>
                                <small class="text-muted" id="panelGroupCount">0 members</small>
                            </div>
                            <button id="groupInfoClose" class="btn btn-sm btn-light" title="Close">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                        
                    </div>
                    
                    <div class="p-3" id="panelMembersList" style="overflow-y:auto; max-height:calc(80vh - 220px);">
                        <!-- Member list injected here --> 
                    </div>
                    <div class="mb-3 p-3" id="GroupInfoAddMembers">
                        <label class="form-label text-muted small fw-bold">Add new members</label>
                        
                        <div class="search-wrapper_chat mb-2" style="max-width:100%; position:relative;">
                            <input type="text" id="searchInput_panel" class="form-control border-0" 
                                placeholder="Search followers..." aria-label="Search" autocomplete="off" />
                            <div id="searchResults_panel" class="search-results bg-white border rounded-2 shadow-sm"
                                aria-hidden="true" style="position:absolute; top:100%; left:0; right:0; z-index:1200; max-height:240px; overflow-y:auto; display:none;"></div>
                        </div>
                        
                        <!-- The container for the chips -->
                        <div id="selectedMembers_panel" class="mt-2 d-flex flex-wrap gap-2"></div>
                        
                        <button type="button" id="addMembersBtn_panel" class="btn btn-sm btn-primary w-100 mt-2">Add Selected Members</button>
                    </div>
                    <div class="p-3 border-top">
                        <form id="leaveGroupForm" asp-controller="Group" asp-action="LeaveGroup" method="post">
                            <input type="hidden" name="id" id="groupId_forLeaveGroupForm" />
                        </form>
                        <button type="submit" form="leaveGroupForm" class="btn btn-danger w-100" id="leaveGroupBtn">
                            <i class="bi bi-box-arrow-right me-2"></i>Leave Group
                        </button>
                        <form id="KickForm" asp-controller="Group" asp-action="KickMember" method="post">
                            <input type="hidden" name="groupId" id="groupId_forKickForm" />
                            <input type="hidden" name="userId" id="userId_forKickForm" />
                        </form>
                    </div>
                </div>
 
                 <div class="modal-body bg-light" id="chatMessagesContainer" style="overflow-y: auto;">
                     <!-- Messages injected here -->
                 </div>
 
                 <!-- Footer (Input) -->
                 <div class="modal-footer border-top-0 bg-white">
                     <form id="chatForm" class="w-100 d-flex gap-2">
                         <input type="hidden" id="currentGroupId" />
                         <input type="text" id="chatInput" class="form-control rounded-pill" placeholder="Type a message..." autocomplete="off" />
                         <button type="submit" class="btn btn-purple rounded-circle" style="width: 40px; height: 40px; padding: 0;">
                             <i class="bi bi-send-fill"></i>
                         </button>
                     </form>
                 </div>
            </div>
        </div>
    </div>

}
else
{
    <!-- Landing Page for Guests -->
    <div class="container mt-5 text-center">
        <h1 class="display-4 fw-bold text-purple mb-4">Welcome to unibucGram</h1>
        <p class="lead mb-5">Connect with your university colleagues.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-5">Log In</a>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary btn-lg px-5">Register</a>
        </div>
    </div>
}

