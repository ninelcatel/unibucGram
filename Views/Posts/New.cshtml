@model unibucGram.Models.Post

@{
    ViewData["Title"] = "New Post";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="text-center mb-4">Create a New Post</h2>
    <div class="card p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @* Render summary ONLY if there are errors 
                for some reason it showed a blank box so had to do this
            *@
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
            }

            <div class="mb-3">
                <label asp-for="Content" class="form-label">Caption</label>
                <textarea asp-for="Content" class="form-control" rows="4" placeholder="Write something..."></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label for="media" class="form-label">Image or Video</label>
                <input type="file" id="media" name="media" class="form-control" accept="image/*,video/*">
                <small class="form-text text-muted">You can upload images or videos (with sound)</small>
            </div>

            <div class="mb-3" id="thumbnail-container" style="display: none;">
                <label for="thumbnail" class="form-label">Video Thumbnail</label>
                <input type="file" id="thumbnail" name="thumbnail" class="form-control" accept="image/*">
                <small class="form-text text-muted">Upload a thumbnail image for your video (recommended for better preview)</small>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary">Post</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('media').addEventListener('change', function(e) {
            const file = e.target.files[0];
            const thumbnailContainer = document.getElementById('thumbnail-container');
            
            if (file && file.type.startsWith('video/')) {
                thumbnailContainer.style.display = 'block';
            } else {
                thumbnailContainer.style.display = 'none';
                document.getElementById('thumbnail').value = '';
            }
        });
    </script>
}
