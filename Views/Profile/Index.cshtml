@model unibucGram.Models.User

@{
    ViewData["Title"] = "Profile";
    var posts = ViewBag.Posts as List<unibucGram.Models.Post> ?? new List<unibucGram.Models.Post>();
    var followers = (int)(ViewBag.FollowersCount ?? 0);
    var following = (int)(ViewBag.FollowingCount ?? 0);
    var isOwnProfile = (bool)(ViewBag.IsOwnProfile ?? false);
}

<div class="container mt-4" style="max-width: 1140px;">
    <!-- Profile Header -->
    <div class="card mb-4">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-auto">
                    <img src="@(string.IsNullOrWhiteSpace(Model.PfpURL) ? "/uploads/default_pfp.jpg" : Model.PfpURL)" 
                         alt="Profile Picture" 
                         width="100" 
                         height="100" 
                         class="rounded-circle border border-3 border-purple" />
                </div>
                <div class="col">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
                        <div>
                            <h3 class="mb-1">@Model.FirstName @Model.LastName</h3>
                            <p class="text-muted mb-0">@@@Model.UserName</p>
                        </div>
                        <div class="mt-3 mt-md-0">
                            @if (!isOwnProfile)
                            {
                                var isFollowedByCurrentUser = ViewBag.IsFollowedByCurrentUser as bool? ?? false;
                                <form method="post" asp-controller="Profile" asp-action="FollowToggle" asp-route-userId="@Model.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm @(isFollowedByCurrentUser ? "btn-outline-primary" : "btn-primary")">
                                        @(isFollowedByCurrentUser ? "Unfollow" : "Follow")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-sm btn-outline-primary">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-pencil me-1" viewBox="0 0 16 16">
                                        <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325"/>
                                    </svg>
                                    Edit Profile
                                </a>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Bio))
                    {
                        <p class="mb-3 text-secondary">@Model.Bio</p>
                    }

                    <div class="d-flex gap-4">
                        <div>
                            <strong class="text-purple">@posts.Count</strong>
                            <span class="text-muted">posts</span>
                        </div>
                        <div>
                            <strong class="text-purple">@followers</strong>
                            <span class="text-muted">followers</span>
                        </div>
                        <div>
                            <strong class="text-purple">@following</strong>
                            <span class="text-muted">following</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Posts Section -->
    <div class="card">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 text-purple">Posts</h5>
        </div>
        <div class="card-body p-3">
            @if (!posts.Any())
            {
                <div class="text-center py-5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-images text-muted mb-3" viewBox="0 0 16 16">
                        <path d="M4.502 9a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3"/>
                        <path d="M14.002 13a2 2 0 0 1-2 2h-10a2 2 0 0 1-2-2V5A2 2 0 0 1 2.002 3h10a2 2 0 0 1 2 2zm-1 0V6l-2.646-2.354a.5.5 0 0 0-.63-.062L7.002 7 4.914 5.584a.5.5 0 0 0-.566-.032L1.002 7V13a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1"/>
                    </svg>
                    <p class="text-muted">@(isOwnProfile ? "You haven't" : "This user hasn't") posted anything yet.</p>
                    @if (isOwnProfile)
                    {
                        <a asp-controller="Posts" asp-action="New" class="btn btn-primary mt-2">Create Your First Post</a>
                    }
                </div>
            }
            else
            {
                <div class="row row-cols-3 g-3">
                    @foreach (var post in posts)
                    {
                        <div class="col">
                            <a href="#" class="text-decoration-none post-thumbnail" data-bs-toggle="modal" data-bs-target="#postModal" data-post-id="@post.Id">
                                <div class="card h-100 border-0 shadow-sm" >
                                    @if (!string.IsNullOrEmpty(post.ImageURL))
                                    {
                                        <div class="post-image-container">
                                            <div class="post-image" style="background-image: url('@post.ImageURL');"></div>
                                        </div>
                                    }
                                    <div class="card-body p-2">
                                        @if (!string.IsNullOrEmpty(post.Content))
                                        {
                                            <p class="card-text small text-truncate mb-2" title="@post.Content">@post.Content</p>
                                        }
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="text-muted" style="font-size: 0.7rem;">@post.CreatedAt.ToLocalTime().ToString("M/d/yy")</small>
                                            <div>
                                                <span class="badge bg-light text-dark" style="font-size: 0.65rem;">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" class="bi bi-heart-fill" viewBox="0 0 16 16">
                                                        <path fill-rule="evenodd" d="M8 1.314C12.438-3.248 23.534 4.735 8 15-7.534 4.736 3.562-3.248 8 1.314"/>
                                                    </svg>
                                                    @post.Likes.Count
                                                </span>
                                                <span class="badge bg-light text-dark ms-1" style="font-size: 0.65rem;">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" class="bi bi-chat-fill" viewBox="0 0 16 16">
                                                        <path d="M8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6-.097 1.016-.417 2.13-.771 2.966-.079.186.074.394.273.362 2.256-.37 3.597-.938 4.18-1.234A9 9 0 0 0 8 15"/>
                                                    </svg>
                                                    @post.Comments.Count
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Post Modal -->
<div class="modal fade" id="postModal" tabindex="-1" aria-labelledby="postModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content" style="background: transparent; border: none;">
      <div class="modal-body" id="postModalBody">
        <!-- Post content will be loaded here via AJAX -->
      </div>
    </div>
  </div>
</div>

@section Scripts {
<style>
    .post-image-container {
        position: relative;
        width: 100%;
        padding-top: 100%; 
        overflow: hidden;
        background: #f8f9fa;
        border-radius: 8px 8px 0 0;
    }

    .post-image {
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        background-size: contain; 
        background-position: center;
        background-repeat: no-repeat; 
    }

    .border-purple {
        border-color: var(--primary-purple) !important;
    }

    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(111, 66, 193, 0.15) !important;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const postModal = document.getElementById('postModal');
        postModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const postId = button.getAttribute('data-post-id');
            const modalBody = document.getElementById('postModalBody');
            
            // Show a loading spinner
            modalBody.innerHTML = '<div class="d-flex justify-content-center"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';

            // Fetch post content
            fetch(`/Posts/PostPartial/${postId}`)
                .then(response => response.text())
                .then(html => {
                    modalBody.innerHTML = html;
                })
                .catch(err => {
                    modalBody.innerHTML = '<p class="text-danger">Failed to load post. Please try again.</p>';
                });
        });

        // Add event listeners for dynamic content inside the modal
        const modalBody = document.getElementById('postModalBody');

        modalBody.addEventListener('submit', function(e) {
            const addCommentForm = e.target.closest('.add-comment-form');
            const editCommentForm = e.target.closest('.edit-comment-form');

            // Handle Add Comment
            if (addCommentForm) {
                e.preventDefault();
                const postId = addCommentForm.dataset.postId;
                const input = addCommentForm.querySelector('input[name="commentText"]');
                const content = input.value;

                if (!content.trim()) return;

                fetch('/Comments/Add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: `postId=${postId}&content=${encodeURIComponent(content)}`
                }).then(response => response.text()).then(html => {
                    const commentsContainer = document.getElementById(`comments-for-modal-${postId}`);
                    if (commentsContainer) {
                        commentsContainer.insertAdjacentHTML('beforeend', html);
                    }
                    input.value = '';
                }).catch(error => console.error('Error adding comment:', error));
            }

            // Handle Edit Comment
            if (editCommentForm) {
                e.preventDefault();
                const commentId = editCommentForm.dataset.commentId;
                const content = editCommentForm.querySelector('input[name="content"]').value;

                fetch(`/Comments/Edit/${commentId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: `content=${encodeURIComponent(content)}`
                }).then(response => response.json()).then(data => {
                    if (data.success) {
                        document.getElementById(`comment-content-${commentId}`).textContent = data.content;
                        document.getElementById(`comment-display-${commentId}`).style.display = 'flex';
                        editCommentForm.style.display = 'none';
                    } else {
                        alert(data.message || 'Failed to edit comment.');
                    }
                }).catch(() => alert('An error occurred.'));
            }
        });

        modalBody.addEventListener('click', function(e) {
            const editButton = e.target.closest('.edit-comment-btn');
            const deleteButton = e.target.closest('.delete-comment-btn');

            // Handle Edit Button Click
            if (editButton) {
                const commentId = editButton.dataset.commentId;
                document.getElementById(`comment-display-${commentId}`).style.display = 'none';
                const editForm = document.querySelector(`.edit-comment-form[data-comment-id='${commentId}']`);
                editForm.style.display = 'block';
                editForm.querySelector('input[name="content"]').focus();
            }

            // Handle Delete Button Click
            if (deleteButton) {
                const commentId = deleteButton.dataset.commentId;
                if (confirm('Are you sure you want to delete this comment?')) {
                    fetch(`/Comments/Delete/${commentId}`, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    }).then(response => response.json()).then(data => {
                        if (data.success) {
                            document.getElementById(`comment-container-${commentId}`).remove();
                        } else {
                            alert(data.message || 'Failed to delete comment.');
                        }
                    }).catch(() => alert('An error occurred.'));
                }
            }
        });
    });
</script>
}