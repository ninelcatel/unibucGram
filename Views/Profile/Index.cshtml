@model unibucGram.Models.User

@{
    ViewData["Title"] = "Profile";
    var posts = ViewBag.Posts as List<unibucGram.Models.Post> ?? new List<unibucGram.Models.Post>();
    var followers = (int)(ViewBag.FollowersCount ?? 0);
    var following = (int)(ViewBag.FollowingCount ?? 0);
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-3">
        <img src="@(string.IsNullOrWhiteSpace(Model.PfpURL) ? "/uploads/default_pfp.jpg" : Model.PfpURL)" alt="avatar" width="80" height="80" class="rounded-circle me-3 align-items-center" />
        <div>
            <h3>@(Model.FirstName) @(Model.LastName)</h3>
            <div class="text-muted">@Model.UserName</div>
            @if (!string.IsNullOrWhiteSpace(Model.Bio)) { <p class="mt-2">@Model.Bio</p> }
            @if (!isOwnProfile)
            {   
                var isFollowedByCurrentUser = ViewBag.IsFollowedByCurrentUser as bool? ?? false;
                <form method="post" asp-controller="Profile" asp-action="FollowToggle" asp-route-userId="@Model.Id" style="display:inline;">
              
                    <button type="submit" class="btn btn-follow btn-sm mt-2">
                        @(isFollowedByCurrentUser ? "Unfollow" : "Follow")
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="Profile" asp-action="Edit" class="btn btn-sm btn-outline-secondary mt-2">Edit Profile</a>
            }
            <div class="mt-2">
                <strong>@posts.Count</strong> posts
                <strong class="ms-3">@followers</strong> followers
                <strong class="ms-3">@following</strong> following
            </div>
        </div>
    </div>

    <hr />

    <h4>Posts</h4>
    <div class="row">
        @if (!posts.Any())
        {
            <div class="col">
                <p class="text-muted">You have no posts yet.</p>
            </div>
        }
        else
        {
            foreach (var post in posts)
            {
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(post.ImageURL))
                            {
                                <div class="post-image-container mb-2">
                                        <div class="post-image" style="background-image: url('@post.ImageURL');"></div>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(post.Content))
                            {
                                <p>@post.Content</p>
                            }
                            <div class="text-muted small">@post.CreatedAt.ToLocalTime().ToString("g") • Likes: @post.Likes.Count • Comments: @post.Comments.Count</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<style>
    .post-image-container {
        position: relative;
        width: 100%;
        padding-top: 100%; 
        overflow: hidden;
        background: #f8f9fa;
        border-radius: 8px 8px 0 0;
    }

    .post-image {
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        background-size: cover; 
        background-position: center;
        background-repeat: no-repeat; 
    }

    .border-purple {
        border-color: var(--primary-purple) !important;
    }

    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(111, 66, 193, 0.15) !important;
    }
</style>
}