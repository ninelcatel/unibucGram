@using Microsoft.AspNetCore.Identity
@using unibucGram.Models
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@{
    ViewData["Title"] = "Manage Posts";
}
@model IEnumerable<unibucGram.Models.Post>

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0">
                    <i class="bi bi-grid-3x3-gap-fill text-primary me-2"></i>
                    Manage Posts
                </h2>
                <span class="badge bg-secondary">@Model.Count() Total Posts</span>
            </div>
            
            <!-- Search Bar -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" 
                               class="form-control border-start-0" 
                               id="postSearchInput" 
                               placeholder="Search posts by content or author username..." 
                               autocomplete="off">
                    </div>
                    <div id="postSearchResults" class="mt-3" style="display: none;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 10%;">ID</th>
                            <th style="width: 40%;">Content</th>
                            <th style="width: 20%;">Author</th>
                            <th style="width: 15%;">Date</th>
                            <th style="width: 15%;" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No posts found
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var post in Model)
                            {
                                var author = await UserManager.FindByIdAsync(post.UserId);
                                <tr>
                                    <td class="text-muted">#@post.Id</td>
                                    <td>
                                        <a asp-controller="Posts" asp-action="Post" asp-route-id="@post.Id" 
                                           class="text-decoration-none text-dark" target="_blank">
                                            <div class="d-flex align-items-start gap-2">
                                                @if (!string.IsNullOrEmpty(post.ImageURL))
                                                {
                                                    <img src="@post.ImageURL" 
                                                         alt="Post image" 
                                                         class="rounded" 
                                                         style="width: 50px; height: 50px; object-fit: cover;">
                                                }
                                                <div class="flex-grow-1">
                                                    <p class="mb-0 text-truncate" style="max-width: 400px;">
                                                        @(string.IsNullOrEmpty(post.Content) ? "(No content)" : post.Content)
                                                    </p>
                                                </div>
                                            </div>
                                        </a>
                                    </td>
                                    <td>
                                        <a asp-controller="Profile" asp-action="Show" asp-route-name="@author.UserName" 
                                           class="text-decoration-none" target="_blank">
                                            <div class="d-flex align-items-center gap-2">
                                                <img src="@(string.IsNullOrEmpty(author.PfpURL) ? "/uploads/default_pfp.jpg" : author.PfpURL)" 
                                                     alt="@author.UserName" 
                                                     class="rounded-circle" 
                                                     style="width: 32px; height: 32px; object-fit: cover;">
                                                <span class="fw-semibold">@author.UserName</span>
                                            </div>
                                        </a>
                                    </td>
                                    <td class="text-muted small">
                                        @post.CreatedAt.ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="Posts" asp-action="Post" asp-route-id="@post.Id" 
                                               class="btn btn-sm btn-outline-primary" 
                                               target="_blank"
                                               title="View Post">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="EditPost" asp-route-id="@post.Id" 
                                                   class="btn btn-sm btn-outline-secondary"
                                                   title="Edit Post">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-action="DeletePost" asp-route-id="@post.Id" 
                                                      method="post" 
                                                      class="d-inline" 
                                                      onsubmit="return confirm('⚠️ Are you sure you want to permanently delete this post?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" 
                                                            class="btn btn-sm btn-outline-danger" 
                                                            title="Delete Post">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const postSearchInput = document.getElementById('postSearchInput');
        const postSearchResults = document.getElementById('postSearchResults');
        
        if (postSearchInput && postSearchResults) {
            let searchTimeout;
            
            postSearchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                const query = this.value.trim();
                
                if (!query) {
                    postSearchResults.innerHTML = '';
                    postSearchResults.style.display = 'none';
                    return;
                }
                
                searchTimeout = setTimeout(() => {
                    fetch(`/Search/DashboardPosts?q=${encodeURIComponent(query)}`, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(res => res.text())
                    .then(html => {
                        postSearchResults.innerHTML = html;
                        postSearchResults.style.display = 'block';
                    })
                    .catch(err => console.error('Search error:', err));
                }, 300);
            });
        }
    </script>
}
