@using Microsoft.AspNetCore.Identity
@using unibucGram.Models
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@{
    ViewData["Title"] = "Manage Posts";
}
@model IEnumerable<unibucGram.Models.Post>

<h2 class="text-center mt-4">Manage Posts</h2>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var post in Model)
        {
            <tr>
                <td>@post.Content</td>
                <td>@UserManager.FindByIdAsync(post.UserId).Result.UserName</td>
                <td>
                    <a asp-controller="Dashboard" asp-action="EditPost" asp-route-id="@post.Id" class="btn btn-sm btn-warning">Edit</a>
                    
               
                    <form asp-action="DeletePost" asp-route-id="@post.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this post? This cannot be undone.');">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
