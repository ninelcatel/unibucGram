@model unibucGram.Models.EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
}

<div class="container py-4" style="max-width: 800px;">
    <div class="card shadow-sm">
        <div class="card-header text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="bi bi-pencil-square me-2"></i>Edit User: <span style="color: var(--primary-purple);">@Model.UserName</span>
            </h4>
            <a asp-controller="Dashboard" asp-action="ManageUsers" class="btn btn-sm btn-primary">
                <i class="bi bi-arrow-left me-1 "></i>Back to Users Management
            </a>
        </div>
        <div class="card-body p-4">
        
            <form asp-action="EditUser" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="PfpURL" />
                <div class="mb-3">
                    <label asp-for="UserName" class="form-label fw-semibold"></label>
                    <input asp-for="UserName" class="form-control" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label fw-semibold"></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label fw-semibold"></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Bio" class="form-label fw-semibold"></label>
                    <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Bio" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProfilePictureFile" class="form-label fw-semibold"></label>
                    <input asp-for="ProfilePictureFile" class="form-control" type="file" accept="image/*" />
                    <span asp-validation-for="ProfilePictureFile" class="text-danger small"></span>
                    @if (!string.IsNullOrEmpty(Model.PfpURL))
                    {
                        <img src="@Model.PfpURL" alt="Profile Picture" class="mt-2 rounded-circle" style="width: 80px; height: 80px; object-fit: cover;" />
                    }
                    <button type="button" class="btn btn-danger btn-sm mt-2" id="removeProfilePictureBtn" onclick="document.getElementById('PfpURL').value=''; 
                                                                            this.previousElementSibling.src='/uploads/default_pfp.jpg';">
                        <i class="bi bi-x-circle me-1"></i>Remove Profile Picture
                    </button>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-2"><i class="bi bi-shield-check me-2"></i>User Roles (Admin Only)</h5>
                    </div>
                    <div class="card-body mb-2">
                        <div class="form-check mb-2">
                            <input asp-for="IsAdmin" class="form-check-input purple-checkbox" style="margin-left: 10px;" />
                            <label asp-for="IsAdmin" class="form-check-label" style="margin-left: 10px;">
                                <span class="badge bg-danger me-2">
                                    <i class="bi bi-shield-fill-check"></i>
                                </span>
                                Admin (Full access to all features)
                            </label>
                        </div>
                        <div class="form-check mb-2">
                            <input asp-for="IsEditor" class="form-check-input purple-checkbox" style="margin-left: 10px;" />
                            <label asp-for="IsEditor" class="form-check-label" style="margin-left: 10px;">
                                <span class="badge bg-warning text-dark me-2">
                                    <i class="bi bi-pencil-square"></i>
                                </span>
                                Editor (Can view dashboard but cannot delete)
                            </label>
                        </div>
                        <div class="form-check">
                            <input asp-for="IsUser" class="form-check-input purple-checkbox" style="margin-left: 10px;" />
                            <label asp-for="IsUser" class="form-check-label" style="margin-left: 10px;">
                                <span class="badge bg-secondary me-2">
                                    <i class="bi bi-person"></i>
                                </span>
                                User (Standard user access)
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="ManageUsers" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}