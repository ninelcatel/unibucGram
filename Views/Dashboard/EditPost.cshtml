@model unibucGram.Models.EditPostViewModel
@{
    ViewData["Title"] = "Edit Post";
}

<div class="container py-4" style="max-width: 800px;">
    <div class="card shadow-sm">
        <div class="card-header text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="bi bi-pencil-square me-2"></i>Edit Post: <span style="color: var(--primary-purple);">#@Model.PostId</span>
            </h4>
            <a asp-controller="Dashboard" asp-action="ManagePosts" class="btn btn-sm btn-primary">
                <i class="bi bi-arrow-left me-1 "></i>Back to Posts Management
            </a>
        </div>
        <div class="card-body p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            <div class="alert alert-info mb-4">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Author:</strong> @Model.AuthorUsername
            </div>

            <form asp-action="EditPost" method="post" enctype="multipart/form-data" id="editPostForm">
                <input type="hidden" asp-for="PostId" />
                <input type="hidden" asp-for="AuthorUsername" />
                <input type="hidden" asp-for="ImageURL" />
                
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                
                <div class="mb-3">
                    <label asp-for="Content" class="form-label fw-semibold"></label>
                    <textarea asp-for="Content" class="form-control" rows="5" placeholder="Post content..." maxlength="2000"></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                    <small class="form-text text-muted"><span id="contentCounter">0</span>/2000 characters</small>
                </div>

                <div class="mb-4">
                    <label asp-for="NewImage" class="form-label fw-semibold"></label>
                    <input asp-for="NewImage" class="form-control" type="file" accept="image/*" />
                    <small class="form-text text-muted">Uploading a new image will replace the current one.</small>
                    <span asp-validation-for="NewImage" class="text-danger small"></span>
                    @if (!string.IsNullOrEmpty(Model.ImageURL))
                    {
                        <img src="@Model.ImageURL" alt="Post Image" class="mt-3 rounded w-100" style="max-height: 400px; object-fit: cover;" />
                    }
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="ManagePosts" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Content character counter
            var contentTextarea = $('#Content');
            var contentCounter = $('#contentCounter');
            
            function updateContentCounter() {
                var count = contentTextarea.val().length;
                contentCounter.text(count);
                if (count > 2000) {
                    contentCounter.css('color', 'red');
                } else {
                    contentCounter.css('color', 'inherit');
                }
            }
            
            contentTextarea.on('input', updateContentCounter);
            updateContentCounter(); // Initialize counter
            
            // Custom validation: post must have content OR image
            $.validator.addMethod("contentOrImage", function(value, element) {
                var hasContent = $('#Content').val().trim().length > 0;
                var hasExistingImage = $('#ImageURL').val().length > 0;
                var hasNewImage = $('#NewImage').val().length > 0;
                return hasContent || hasExistingImage || hasNewImage;
            }, "Post must have either content text or an image.");
            
            // Apply custom validation
            $('#Content').rules('add', {
                contentOrImage: true
            });
            
            // Form submission validation
            $('#editPostForm').validate({
                errorClass: 'text-danger small',
                errorElement: 'span',
                highlight: function(element) {
                    $(element).addClass('is-invalid');
                },
                unhighlight: function(element) {
                    $(element).removeClass('is-invalid');
                },
                submitHandler: function(form) {
                    // Additional check before submission
                    var hasContent = $('#Content').val().trim().length > 0;
                    var hasExistingImage = $('#ImageURL').val().length > 0;
                    var hasNewImage = $('#NewImage').val().length > 0;
                    
                    if (!hasContent && !hasExistingImage && !hasNewImage) {
                        alert('Post must have either content text or an image.');
                        return false;
                    }
                    
                    form.submit();
                }
            });
        });
    </script>
}