@model unibucGram.Models.EditPostViewModel
@{
    ViewData["Title"] = "Edit Post";
}

<div class="container py-4" style="max-width: 800px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                <i class="bi bi-pencil-square me-2"></i>Edit Post #@Model.PostId
            </h4>
        </div>
        <div class="card-body p-4">
            <div class="alert alert-info mb-4">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Author:</strong> @Model.AuthorUsername
            </div>

            <form asp-action="EditPost" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="PostId" />
                <input type="hidden" asp-for="AuthorUsername" />
                
                <div class="mb-3">
                    <label asp-for="Content" class="form-label fw-semibold"></label>
                    <textarea asp-for="Content" class="form-control" rows="5" placeholder="Post content..."></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NewImage" class="form-label fw-semibold"></label>
                    <input asp-for="NewImage" class="form-control" type="file" accept="image/*" />
                    <small class="form-text text-muted">Uploading a new image will replace the current one.</small>
                    <span asp-validation-for="NewImage" class="text-danger small"></span>
                    @if (!string.IsNullOrEmpty(Model.ImageURL))
                    {
                        <img src="@Model.ImageURL" alt="Post Image" class="mt-3 rounded w-100" style="max-height: 400px; object-fit: cover;" />
                    }
                    <button type="button" class="btn btn-danger btn-sm mt-2" id="removePostImageBtn" onclick="document.getElementById('ImageURL').value=''; 
                    this.previousElementSibling.src='';">
                        <i class="bi bi-x-circle me-1"></i>Remove Post Image
                    </button>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="ManagePosts" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}