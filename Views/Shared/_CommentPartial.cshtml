@using Microsoft.AspNetCore.Identity
@model unibucGram.Models.Comment
@inject UserManager<unibucGram.Models.User> UserManager

@{
    var currentUserId = UserManager.GetUserId(User);
}

<div class="comment-container mb-2" id="comment-container-@Model.Id">
    <div class="d-flex justify-content-between align-items-start" id="comment-display-@Model.Id">
        <div class="small">
            <a asp-controller="Profile" asp-action="Show" asp-route-name="@Model.User.UserName" class="fw-bold text-dark text-decoration-none">
                @Model.User.UserName
            </a>
            <span id="comment-content-@Model.Id">@Model.Content</span>
            <br>
            <small class="text-muted">@Model.CreatedAt.ToLocalTime().ToString("g")</small>
        </div>
        @if (Model.UserId == currentUserId)
        {
            <div class="d-flex">
                <button class="btn btn-link text-primary p-0 edit-comment-btn" data-comment-id="@Model.Id" title="Edit Comment"><i class="bi bi-pencil-fill"></i></button>
                <button class="btn btn-link text-danger p-0 ms-2 delete-comment-btn" data-comment-id="@Model.Id" title="Delete Comment"><i class="bi bi-trash3-fill"></i></button>
            </div>
        }
    </div>
    @if (Model.UserId == currentUserId)
    {
        <form class="edit-comment-form w-100 mt-1" data-comment-id="@Model.Id" style="display: none;">
            <input type="text" name="content" class="form-control form-control-sm" value="@Model.Content" required>
        </form>
    }
</div>