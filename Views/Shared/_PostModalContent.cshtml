@using Microsoft.AspNetCore.Identity
@model unibucGram.Models.Post
@inject UserManager<unibucGram.Models.User> UserManager
@{
    var currentUserId = UserManager.GetUserId(User);
    var isTextOnly = string.IsNullOrEmpty(Model.ImageURL) && string.IsNullOrEmpty(Model.VideoURL);
    var hasVideo = !string.IsNullOrEmpty(Model.VideoURL);
}
<div class="card border-0 @(isTextOnly ? "text-only-modal" : "")" id="post-modal-@Model.Id">
    @if (!isTextOnly)
    {
        <div class="row g-0">
            <div class="col-md-7" style="background: #000; display: flex; align-items: center; justify-content: center; max-height: 500px; overflow: hidden;">
                @if (hasVideo)
                {
                    <video controls class="w-100 h-100 rounded-start" style="max-height: 500px; object-fit: contain;" controlsList="nodownload" playsinline>
                        <source src="@Model.VideoURL" type="video/mp4">
                        <source src="@Model.VideoURL" type="video/webm">
                        <source src="@Model.VideoURL" type="video/ogg">
                        Your browser does not support the video tag.
                    </video>
                }
                else
                {
                    <img src="@Model.ImageURL" class="img-fluid rounded-start w-100" style="object-fit: contain; max-height: 500px;" alt="Post Image">
                }
            </div>
            <div class="col-md-5 d-flex flex-column">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <a asp-controller="Profile" asp-action="Show" asp-route-name="@Model.User.UserName" class="text-decoration-none text-dark d-flex align-items-center">
                        <img src="@(string.IsNullOrWhiteSpace(Model.User.PfpURL) ? "/uploads/default_pfp.jpg" : Model.User.PfpURL)"
                             alt="avatar" width="32" height="32" class="rounded-circle me-2" />
                        <strong>@Model.User.UserName</strong>
                    </a>
                    @if (Model.UserId == currentUserId)
                    {
                        <div class="dropdown">
                            <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a asp-controller="Posts" asp-action="Edit" asp-route-id="@Model.Id" class="dropdown-item"><i class="bi bi-pencil-square me-2"></i>Edit</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Posts" asp-action="Delete" method="post" onsubmit="return confirm('Delete this post?');">
                                        <input type="hidden" name="postId" value="@Model.Id" />
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash3-fill me-2"></i>Delete</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
                <div class="card-body d-flex flex-column">
                    @if (!string.IsNullOrWhiteSpace(Model.Content))
                    {
                        <div class="mb-2">
                            <a asp-controller="Profile" asp-action="Show" asp-route-name="@Model.User.UserName" class="fw-bold text-dark text-decoration-none">@Model.User.UserName</a>
                            <span>@Model.Content</span>
                        </div>
                    }
                    <div class="flex-grow-1 overflow-auto mb-3" id="modal-comments-container-@Model.Id" style="max-height: 400px; overflow-y: auto;">
                        <div class="comments-container mt-2" id="comments-for-modal-@Model.Id">
                            @foreach(var comment in Model.Comments.OrderBy(c => c.CreatedAt).Take(10))
                            {
                                @if (comment.User != null)
                                { <partial name="_CommentPartial" model="comment" /> }
                            }
                        </div>
                        @if (Model.Comments.Count > 10)
                        {
                            <div class="text-center py-2 modal-comments-loading" style="display: none;">
                                <div class="spinner-border spinner-border-sm text-purple" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="mt-auto">
                        <div class="d-flex align-items-center gap-2 border-top pt-2">
                            @{
                                var isLiked = Model.Likes.Any(l => l.UserId == currentUserId);
                            }
                            <button class="btn btn-link text-dark p-0 like-button" data-post-id="@Model.Id">
                                <i class="bi @(isLiked ? "bi-heart-fill text-danger" : "bi-heart") fs-5"></i>
                            </button>
                            <span class="fw-bold small likes-count">@Model.Likes.Count likes</span>
                            
                            <button class="btn btn-link text-dark p-0 ms-2">
                                <i class="bi bi-chat fs-5"></i>
                            </button>
                            <span class="fw-bold small comments-count">@Model.Comments.Count comments</span>
                            
                            <button class="btn btn-link text-dark p-0 ms-2 share-button" data-post-id="@Model.Id">
                                <i class="bi bi-send fs-5"></i>
                            </button>
                        </div>
                        <div class="text-muted small mt-2">@Model.CreatedAt.ToLocalTime().ToString("D").ToUpper()</div>
                        
                        @* Preview ultimele 3 comentarii *@
                        @if (Model.Comments.Any())
                        {
                            <div class="mt-2 pt-2 border-top">
                                @foreach(var comment in Model.Comments.OrderByDescending(c => c.CreatedAt).Take(3).Reverse())
                                {
                                    @if (comment.User != null)
                                    {
                                        <div class="d-flex align-items-start mb-2">
                                            <a href="/Profile/Show/@comment.User.UserName" class="text-decoration-none">
                                                <img src="@(string.IsNullOrWhiteSpace(comment.User.PfpURL) ? "/uploads/default_pfp.jpg" : comment.User.PfpURL)"
                                                     alt="avatar" width="24" height="24" class="rounded-circle me-2" style="object-fit: cover;" />
                                            </a>
                                            <div class="flex-grow-1" style="font-size: 0.9rem;">
                                                <a href="/Profile/Show/@comment.User.UserName" class="fw-bold text-dark text-decoration-none">@comment.User.UserName</a>
                                                <span class="text-muted">@comment.Content</span>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-white p-2">
                    <form class="add-comment-form" data-post-id="@Model.Id">
                        <input type="text" name="commentText" class="form-control form-control-sm" placeholder="Add a comment..." />
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-only-wrapper p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <a asp-controller="Profile" asp-action="Show" asp-route-name="@Model.User.UserName" class="text-decoration-none text-dark d-flex align-items-center">
                    <img src="@(string.IsNullOrWhiteSpace(Model.User.PfpURL) ? "/uploads/default_pfp.jpg" : Model.User.PfpURL)"
                         alt="avatar" width="40" height="40" class="rounded-circle me-2" />
                    <strong class="fs-5">@Model.User.UserName</strong>
                </a>
                @if (Model.UserId == currentUserId)
                {
                    <a asp-controller="Posts" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                }
            </div>
            <div class="text-only-content mb-4">
                @if (!string.IsNullOrWhiteSpace(Model.Content))
                {
                    <p class="lead mb-0">@Model.Content</p>
                }
                else
                {
                    <p class="fst-italic text-muted mb-0">No caption</p>
                }
            </div>
            <div class="border-top pt-3 mb-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    @{
                        var isLiked = Model.Likes.Any(l => l.UserId == currentUserId);
                    }
                    <button class="btn btn-link p-0 like-button" data-post-id="@Model.Id">
                        <i class="bi @(isLiked ? "bi-heart-fill text-danger" : "bi-heart") fs-4"></i>
                    </button>
                    <span class="fw-semibold small likes-count">@Model.Likes.Count likes</span>
                    
                    <button class="btn btn-link p-0 ms-2">
                        <i class="bi bi-chat fs-4"></i>
                    </button>
                    <span class="fw-semibold small comments-count">@Model.Comments.Count comments</span>
                    
                    <button class="btn btn-link p-0 ms-2 share-button" data-post-id="@Model.Id">
                        <i class="bi bi-send fs-4"></i>
                    </button>
                </div>
                <div class="text-muted small">@Model.CreatedAt.ToLocalTime().ToString("g")</div>
                
                @* Preview ultimele 3 comentarii *@
                @if (Model.Comments.Any())
                {
                    <div class="mt-3 pt-2 border-top">
                        @foreach(var comment in Model.Comments.OrderByDescending(c => c.CreatedAt).Take(3).Reverse())
                        {
                            @if (comment.User != null)
                            {
                                <div class="d-flex align-items-start mb-2">
                                    <a href="/Profile/Show/@comment.User.UserName" class="text-decoration-none">
                                        <img src="@(string.IsNullOrWhiteSpace(comment.User.PfpURL) ? "/uploads/default_pfp.jpg" : comment.User.PfpURL)"
                                             alt="avatar" width="28" height="28" class="rounded-circle me-2" style="object-fit: cover;" />
                                    </a>
                                    <div class="flex-grow-1">
                                        <a href="/Profile/Show/@comment.User.UserName" class="fw-bold text-dark text-decoration-none">@comment.User.UserName</a>
                                        <span class="text-muted">@comment.Content</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
            <div id="modal-comments-container-@Model.Id" style="max-height: 350px; overflow-y: auto;" class="mb-3">
                <div class="comments-container" id="comments-for-modal-@Model.Id">
                    @foreach(var comment in Model.Comments.OrderBy(c => c.CreatedAt).Take(10))
                    {
                        @if (comment.User != null)
                        { <partial name="_CommentPartial" model="comment" /> }
                    }
                </div>
                @if (Model.Comments.Count > 10)
                {
                    <div class="text-center py-2 modal-comments-loading" style="display: none;">
                        <div class="spinner-border spinner-border-sm text-purple" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
            </div>
            <form class="add-comment-form" data-post-id="@Model.Id">
                <input type="text" name="commentText" class="form-control form-control-sm" placeholder="Add a comment..." />
            </form>
        </div>
    }
</div>