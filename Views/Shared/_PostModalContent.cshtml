@using Microsoft.AspNetCore.Identity
@model unibucGram.Models.Post
@inject UserManager<unibucGram.Models.User> UserManager
@{
    var currentUserId = UserManager.GetUserId(User);
    var isTextOnly = string.IsNullOrEmpty(Model.ImageURL);
}
<div class="card border-0 @(isTextOnly ? "text-only-modal" : "")" id="post-modal-@Model.Id">
    @if (!isTextOnly)
    {
        <div class="row g-0">
            <div class="col-md-7">
                <img src="@Model.ImageURL" class="img-fluid rounded-start w-100" style="object-fit: cover; height: 100%;" alt="Post Image">
            </div>
            <div class="col-md-5 d-flex flex-column">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <a asp-controller="Profile" asp-action="Show" asp-route-name="@Model.User.UserName" class="text-decoration-none text-dark d-flex align-items-center">
                        <img src="@(string.IsNullOrWhiteSpace(Model.User.PfpURL) ? "/uploads/default_pfp.jpg" : Model.User.PfpURL)"
                             alt="avatar" width="32" height="32" class="rounded-circle me-2" />
                        <strong>@Model.User.UserName</strong>
                    </a>
                    @if (Model.UserId == currentUserId)
                    {
                        <div class="dropdown">
                            <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a asp-controller="Posts" asp-action="Edit" asp-route-id="@Model.Id" class="dropdown-item"><i class="bi bi-pencil-square me-2"></i>Edit</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Posts" asp-action="Delete" method="post" onsubmit="return confirm('Delete this post?');">
                                        <input type="hidden" name="postId" value="@Model.Id" />
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash3-fill me-2"></i>Delete</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
                <div class="card-body d-flex flex-column">
                    @if (!string.IsNullOrWhiteSpace(Model.Content))
                    {
                        <div class="mb-2">
                            <a asp-controller="Profile" asp-action="Show" asp-route-name="@Model.User.UserName" class="fw-bold text-dark text-decoration-none">@Model.User.UserName</a>
                            <span>@Model.Content</span>
                        </div>
                    }
                    <div class="flex-grow-1 overflow-auto mb-3">
                        <div class="comments-container mt-2" id="comments-for-modal-@Model.Id">
                            @foreach(var comment in Model.Comments.OrderBy(c => c.CreatedAt))
                            {
                                @if (comment.User != null)
                                { <partial name="_CommentPartial" model="comment" /> }
                            }
                        </div>
                    </div>
                    <div class="mt-auto">
                        <div class="d-flex align-items-center gap-3 border-top pt-2">
                            @{
                                var isLiked = Model.Likes.Any(l => l.UserId == currentUserId);
                            }
                            <button class="btn btn-link text-dark p-0 like-button" data-post-id="@Model.Id">
                                <i class="bi @(isLiked ? "bi-heart-fill text-danger" : "bi-heart") fs-5"></i>
                            </button>
                            <div class="text-dark d-flex align-items-center gap-1">
                                <i class="bi bi-chat fs-5"></i>
                            </div>
                        </div>
                        <div class="likes-count fw-bold small mt-1">@Model.Likes.Count likes</div>
                        <div class="text-muted small mt-1">@Model.CreatedAt.ToLocalTime().ToString("D").ToUpper()</div>
                    </div>
                </div>
                <div class="card-footer bg-white p-2">
                    <form class="add-comment-form" data-post-id="@Model.Id">
                        <input type="text" name="commentText" class="form-control form-control-sm" placeholder="Add a comment..." />
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-only-wrapper p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <a asp-controller="Profile" asp-action="Show" asp-route-name="@Model.User.UserName" class="text-decoration-none text-dark d-flex align-items-center">
                    <img src="@(string.IsNullOrWhiteSpace(Model.User.PfpURL) ? "/uploads/default_pfp.jpg" : Model.User.PfpURL)"
                         alt="avatar" width="40" height="40" class="rounded-circle me-2" />
                    <strong class="fs-5">@Model.User.UserName</strong>
                </a>
                @if (Model.UserId == currentUserId)
                {
                    <a asp-controller="Posts" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                }
            </div>
            <div class="text-only-content mb-4">
                @if (!string.IsNullOrWhiteSpace(Model.Content))
                {
                    <p class="lead mb-0">@Model.Content</p>
                }
                else
                {
                    <p class="fst-italic text-muted mb-0">No caption</p>
                }
            </div>
            <div class="d-flex align-items-center gap-3 mb-3">
                @{
                    var isLiked = Model.Likes.Any(l => l.UserId == currentUserId);
                }
                <button class="btn btn-link p-0 like-button" data-post-id="@Model.Id">
                    <i class="bi @(isLiked ? "bi-heart-fill text-danger" : "bi-heart") fs-4"></i>
                </button>
                <span class="fw-semibold">@Model.Likes.Count likes</span>
                <span class="text-muted small">@Model.CreatedAt.ToLocalTime().ToString("g")</span>
            </div>
            <div class="comments-container mb-3" id="comments-for-modal-@Model.Id">
                @foreach(var comment in Model.Comments.OrderBy(c => c.CreatedAt))
                {
                    @if (comment.User != null)
                    { <partial name="_CommentPartial" model="comment" /> }
                }
            </div>
            <form class="add-comment-form" data-post-id="@Model.Id">
                <input type="text" name="commentText" class="form-control form-control-sm" placeholder="Add a comment..." />
            </form>
        </div>
    }
</div>